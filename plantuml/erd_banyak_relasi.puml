@startuml ERD_Banyak_Relasi
' ERD Banyak Relasi - Sistem Informasi Akademik Sekolah (SIAS)
' Notasi: Yourdon & DeMarco (Chen-style ERD)

skinparam backgroundColor white
skinparam defaultFontColor black
skinparam defaultFontName Arial
skinparam monochrome true

title **ERD Banyak Relasi - SIAS**\n//Notasi: Yourdon & DeMarco//

skinparam entity {
    BackgroundColor white
    BorderColor black
    FontSize 12
}

entity "SISWA" as SISWA {
    * <u>NIS</u> <<PK>>
    --
    Nama_Siswa
    Tanggal_Lahir
    Jenis_Kelamin
    Alamat
    No_Telepon
    Agama
}

entity "GURU" as GURU {
    * <u>NIP</u> <<PK>>
    --
    Nama_Guru
    Spesialisasi
    No_Telepon
    Alamat
    Email
    Pendidikan_Terakhir
}

entity "MATA_PELAJARAN" as MAPEL {
    * <u>Kode_Mapel</u> <<PK>>
    --
    Nama_Mapel
    Tingkat_Kelas
    KKM
    Semester
    Kurikulum
}

entity "NILAI\n(Junction Table)" as NILAI {
    * <u>ID_Nilai</u> <<PK>>
    --
    # //NIS// <<FK>>
    # //Kode_Mapel// <<FK>>
    Nilai_Tugas
    Nilai_UTS
    Nilai_UAS
}

' ── Relasi ──
GURU ||--o{ MAPEL : "Mengajar (1:N)"
SISWA ||--o{ NILAI : "Memiliki (1:N)"
MAPEL ||--o{ NILAI : "Untuk (1:N)"

note as Legend
    **Kardinalitas:**
    GURU (1) --- (N) MATA_PELAJARAN
    SISWA (M) --- (N) MATA_PELAJARAN
    → dipecah via tabel NILAI (Junction)
    SISWA (1) --- (N) NILAI
end note

@enduml
