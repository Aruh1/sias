@startuml Tabel_Relasi
' Tabel Relasi - Sistem Informasi Akademik Sekolah (SIAS)

skinparam backgroundColor white
skinparam defaultFontColor black
skinparam defaultFontName Arial

title **Tabel Relasi - Sistem Informasi Akademik Sekolah (SIAS)**

skinparam entity {
    BackgroundColor #f8fafc
    BorderColor #d1d5db
    FontSize 11
}

entity "tb_siswa" as tb_siswa {
    * <color:#dc2626>**[PK] NIS**</color>
    --
    Nama_Siswa
    Tanggal_Lahir
    Jenis_Kelamin
    Alamat
    No_Telepon
    Agama
}

entity "tb_guru" as tb_guru {
    * <color:#dc2626>**[PK] NIP**</color>
    --
    Nama_Guru
    Spesialisasi
    No_Telepon
    Alamat
    Email
    Pendidikan_Terakhir
}

entity "tb_mapel" as tb_mapel {
    * <color:#dc2626>**[PK] Kode_Mapel**</color>
    --
    Nama_Mapel
    Tingkat_Kelas
    KKM
    Semester
    Kurikulum
    # <color:#ea580c>//[FK] NIP//</color>
}

entity "tb_nilai" as tb_nilai {
    * <color:#dc2626>**[PK] ID_Nilai**</color>
    --
    # <color:#ea580c>//[FK] NIS//</color>
    # <color:#ea580c>//[FK] Kode_Mapel//</color>
    Nilai_Tugas
    Nilai_UTS
    Nilai_UAS
}

' ── Foreign Key Relationships ──
tb_guru ||--o{ tb_mapel : "1 : N"
tb_siswa ||--o{ tb_nilai : "1 : N"
tb_mapel ||--o{ tb_nilai : "1 : N"

note bottom
    **Kardinalitas:**
    • GURU (1) --- (N) MATA_PELAJARAN → 1 Guru mengajar banyak Mapel
    • SISWA (M) --- (N) MATA_PELAJARAN → dipecah menjadi tabel NILAI
    • SISWA (1) --- (N) NILAI → 1 Siswa punya banyak Nilai
end note

@enduml
