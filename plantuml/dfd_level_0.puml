@startuml DFD_Level_0
' DFD Level 0 - Sistem Informasi Akademik Sekolah (SIAS)
' Notasi: Yourdon & DeMarco

skinparam backgroundColor white
skinparam defaultFontColor black
skinparam defaultFontName Arial
skinparam monochrome true

title **DFD Level 0 - Sistem Informasi Akademik Sekolah**\n//Notasi: Yourdon & DeMarco//

skinparam rectangle {
    BackgroundColor white
    BorderColor black
    FontSize 14
}

skinparam usecase {
    BackgroundColor white
    BorderColor black
    FontSize 11
}

skinparam arrow {
    Color black
    FontColor black
    FontSize 10
}

rectangle "Siswa" as Siswa
rectangle "Guru" as Guru
rectangle "Admin /\nTata Usaha" as Admin

usecase "0.0\nSistem Informasi\nAkademik Sekolah\n(SIAS)" as SIAS

Siswa --> SIAS : Data Pendaftaran
SIAS --> Siswa : Info Login,\nJadwal, Rapor

Guru --> SIAS : Input Nilai
SIAS --> Guru : Info Jadwal

Admin --> SIAS : Data Siswa, Guru,\nMapel, Jadwal
SIAS --> Admin : Laporan Akademik

@enduml
