@startuml ERD_1_Relasi
' ERD 1 Relasi - GURU (1:N) MATA_PELAJARAN
' Notasi: Yourdon & DeMarco (Chen-style ERD)

skinparam backgroundColor white
skinparam defaultFontColor black
skinparam defaultFontName Arial
skinparam monochrome true

title **ERD 1 Relasi - GURU (1) ---- (N) MATA PELAJARAN**\n//Notasi: Yourdon & DeMarco//

skinparam entity {
    BackgroundColor white
    BorderColor black
    FontSize 13
}

entity "GURU" as GURU {
    * <u>NIP</u> <<PK>>
    --
    Nama_Guru
    Spesialisasi
    No_Telepon
    Alamat
    Email
    Pendidikan_Terakhir
}

entity "MATA_PELAJARAN" as MAPEL {
    * <u>Kode_Mapel</u> <<PK>>
    --
    Nama_Mapel
    Tingkat_Kelas
    KKM
    Semester
    Kurikulum
}

GURU ||--o{ MAPEL : "Mengajar\n(1 : N)"

note bottom of GURU
    1 Guru mengajar
    banyak Mata Pelajaran
end note

@enduml
