// ERD Banyak Relasi - Sistem Informasi Akademik Sekolah (SIAS)
// Notasi: Yourdon & DeMarco (Chen-style ERD)
graph ERD_Banyak_Relasi {
    graph [bgcolor=white, fontname="Arial", pad=0.5, nodesep=0.6, ranksep=1.0,
           label="ERD Banyak Relasi - SIAS\n(Notasi: Yourdon \u0026 DeMarco)",
           labelloc=t, fontsize=14, fontcolor=black];
    node [fontname="Arial", fontcolor=black, color=black];
    edge [fontname="Arial", color=black, penwidth=1.0];

    // ── Entitas (kotak) ──
    SISWA [shape=box, label="SISWA", fontsize=14, penwidth=2];
    GURU [shape=box, label="GURU", fontsize=14, penwidth=2];
    MAPEL [shape=box, label="MATA_PELAJARAN", fontsize=14, penwidth=2];
    NILAI [shape=box, label="NILAI\n(Junction)", fontsize=14, penwidth=2];

    // ── Relasi (diamond) ──
    Mengajar [shape=diamond, label="Mengajar", fontsize=11, penwidth=2];
    Memiliki [shape=diamond, label="Memiliki", fontsize=11, penwidth=2];
    Untuk [shape=diamond, label="Untuk", fontsize=11, penwidth=2];

    // ── Koneksi ──
    GURU -- Mengajar [label="1", fontsize=14];
    Mengajar -- MAPEL [label="N", fontsize=14];
    SISWA -- Memiliki [label="1", fontsize=14];
    Memiliki -- NILAI [label="N", fontsize=14];
    NILAI -- Untuk [label="N", fontsize=14];
    Untuk -- MAPEL [label="1", fontsize=14];

    // ── Atribut SISWA (PK = underlined via HTML) ──
    NIS [shape=ellipse, label=<<U>NIS</U>>, fontsize=9, penwidth=2];
    Nama_Siswa [shape=ellipse, label="Nama_Siswa", fontsize=9];
    Tgl_Lahir [shape=ellipse, label="Tanggal_Lahir", fontsize=9];
    JK [shape=ellipse, label="Jenis_Kelamin", fontsize=9];
    Alamat_S [shape=ellipse, label="Alamat", fontsize=9];
    Telp_S [shape=ellipse, label="No_Telepon", fontsize=9];
    Agama [shape=ellipse, label="Agama", fontsize=9];
    SISWA -- NIS; SISWA -- Nama_Siswa; SISWA -- Tgl_Lahir;
    SISWA -- JK; SISWA -- Alamat_S; SISWA -- Telp_S; SISWA -- Agama;

    // ── Atribut GURU ──
    NIP [shape=ellipse, label=<<U>NIP</U>>, fontsize=9, penwidth=2];
    Nama_Guru [shape=ellipse, label="Nama_Guru", fontsize=9];
    Spesialisasi [shape=ellipse, label="Spesialisasi", fontsize=9];
    Telp_G [shape=ellipse, label="No_Telepon", fontsize=9];
    Alamat_G [shape=ellipse, label="Alamat", fontsize=9];
    Email [shape=ellipse, label="Email", fontsize=9];
    Pend [shape=ellipse, label="Pendidikan_Terakhir", fontsize=9];
    GURU -- NIP; GURU -- Nama_Guru; GURU -- Spesialisasi;
    GURU -- Telp_G; GURU -- Alamat_G; GURU -- Email; GURU -- Pend;

    // ── Atribut MAPEL ──
    Kode_Mapel [shape=ellipse, label=<<U>Kode_Mapel</U>>, fontsize=9, penwidth=2];
    Nama_Mapel [shape=ellipse, label="Nama_Mapel", fontsize=9];
    Tingkat [shape=ellipse, label="Tingkat_Kelas", fontsize=9];
    KKM [shape=ellipse, label="KKM", fontsize=9];
    Semester [shape=ellipse, label="Semester", fontsize=9];
    Kurikulum [shape=ellipse, label="Kurikulum", fontsize=9];
    MAPEL -- Kode_Mapel; MAPEL -- Nama_Mapel; MAPEL -- Tingkat;
    MAPEL -- KKM; MAPEL -- Semester; MAPEL -- Kurikulum;

    // ── Atribut NILAI (FK = dashed) ──
    ID_Nilai [shape=ellipse, label=<<U>ID_Nilai</U>>, fontsize=9, penwidth=2];
    FK_NIS [shape=ellipse, label=<<I>NIS (FK)</I>>, fontsize=9, style=dashed, penwidth=1.5];
    FK_Kode [shape=ellipse, label=<<I>Kode_Mapel (FK)</I>>, fontsize=9, style=dashed, penwidth=1.5];
    N_Tugas [shape=ellipse, label="Nilai_Tugas", fontsize=9];
    N_UTS [shape=ellipse, label="Nilai_UTS", fontsize=9];
    N_UAS [shape=ellipse, label="Nilai_UAS", fontsize=9];
    NILAI -- ID_Nilai; NILAI -- FK_NIS; NILAI -- FK_Kode;
    NILAI -- N_Tugas; NILAI -- N_UTS; NILAI -- N_UAS;
}
