// DFD Level 1 - Sistem Informasi Akademik Sekolah (SIAS)
digraph DFD_Level_1 {
    graph [bgcolor=white, fontname="Arial", pad=0.5, nodesep=0.8, ranksep=1.2,
           label="DFD Level 1 - Sistem Informasi Akademik Sekolah (SIAS)",
           labelloc=t, fontsize=18, fontcolor=black];
    node [fontname="Arial", fontcolor=black, color=black];
    edge [fontname="Arial", fontcolor=black, color=black, fontsize=9];

    // ── Entitas Eksternal ──
    Siswa [shape=box, style="filled,rounded", fillcolor="#dbeafe", color="#2563eb",
           label="Siswa", fontsize=13, penwidth=2];
    Guru [shape=box, style="filled,rounded", fillcolor="#dbeafe", color="#2563eb",
          label="Guru", fontsize=13, penwidth=2];
    Admin [shape=box, style="filled,rounded", fillcolor="#dbeafe", color="#2563eb",
           label="Admin /\nTata Usaha", fontsize=13, penwidth=2];

    // ── Proses ──
    P1 [shape=circle, style=filled, fillcolor="#dcfce7", color="#16a34a",
        label="1.0\nRegistrasi &\nPendataan Siswa", fontsize=9, penwidth=2, width=1.5, fixedsize=true];
    P2 [shape=circle, style=filled, fillcolor="#dcfce7", color="#16a34a",
        label="2.0\nPendataan\nGuru & Mapel", fontsize=9, penwidth=2, width=1.5, fixedsize=true];
    P3 [shape=circle, style=filled, fillcolor="#dcfce7", color="#16a34a",
        label="3.0\nPengaturan\nJadwal", fontsize=9, penwidth=2, width=1.5, fixedsize=true];
    P4 [shape=circle, style=filled, fillcolor="#dcfce7", color="#16a34a",
        label="4.0\nPengelolaan\nNilai", fontsize=9, penwidth=2, width=1.5, fixedsize=true];
    P5 [shape=circle, style=filled, fillcolor="#dcfce7", color="#16a34a",
        label="5.0\nCetak Laporan\nAkademik", fontsize=9, penwidth=2, width=1.5, fixedsize=true];

    // ── Data Store ──
    D1 [shape=record, style=filled, fillcolor="#fef9c3", color="#ca8a04",
        label="{D1|Data Siswa}", fontsize=10, penwidth=1.5];
    D2 [shape=record, style=filled, fillcolor="#fef9c3", color="#ca8a04",
        label="{D2|Data Guru}", fontsize=10, penwidth=1.5];
    D3 [shape=record, style=filled, fillcolor="#fef9c3", color="#ca8a04",
        label="{D3|Data Mapel}", fontsize=10, penwidth=1.5];
    D4 [shape=record, style=filled, fillcolor="#fef9c3", color="#ca8a04",
        label="{D4|Data Jadwal}", fontsize=10, penwidth=1.5];
    D5 [shape=record, style=filled, fillcolor="#fef9c3", color="#ca8a04",
        label="{D5|Data Nilai}", fontsize=10, penwidth=1.5];

    // ── Aliran Data ──
    // P1: Registrasi
    Admin -> P1 [label="Form Data\nSiswa Baru"];
    P1 -> D1 [label="Simpan Data"];
    P1 -> Siswa [label="Info Login"];

    // P2: Pendataan Guru & Mapel
    Admin -> P2 [label="Data Guru\n& Mapel"];
    P2 -> D2 [label="Simpan"];
    P2 -> D3 [label="Simpan"];

    // P3: Pengaturan Jadwal
    Admin -> P3 [label="Susun Jadwal"];
    D2 -> P3 [label="Data Guru"];
    D3 -> P3 [label="Data Mapel"];
    P3 -> D4 [label="Simpan"];
    P3 -> Siswa [label="Info Jadwal"];
    P3 -> Guru [label="Info Jadwal"];

    // P4: Pengelolaan Nilai
    Guru -> P4 [label="Input Nilai\nUjian"];
    D1 -> P4 [label="Validasi Siswa"];
    D3 -> P4 [label="Validasi Mapel"];
    P4 -> D5 [label="Simpan Nilai"];

    // P5: Cetak Laporan
    D1 -> P5 [label="Data Siswa"];
    D4 -> P5 [label="Data Jadwal"];
    D5 -> P5 [label="Data Nilai"];
    P5 -> Siswa [label="Laporan Rapor"];
    P5 -> Admin [label="Arsip Laporan"];
}
