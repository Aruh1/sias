// ERD 1 Relasi - GURU (1:N) MATA_PELAJARAN
// Notasi: Yourdon & DeMarco (Chen-style ERD)
graph ERD_1_Relasi {
    graph [bgcolor=white, fontname="Arial", pad=0.5, nodesep=0.8, ranksep=1.0,
           label="ERD 1 Relasi - GURU (1) ---- (N) MATA PELAJARAN\n(Notasi: Yourdon \u0026 DeMarco)",
           labelloc=t, fontsize=14, fontcolor=black];
    node [fontname="Arial", fontcolor=black, color=black];
    edge [fontname="Arial", color=black, penwidth=1.0];

    // ── Entitas (kotak) ──
    GURU [shape=box, label="GURU", fontsize=14, penwidth=2];
    MAPEL [shape=box, label="MATA_PELAJARAN", fontsize=14, penwidth=2];

    // ── Relasi (diamond) ──
    Mengajar [shape=diamond, label="Mengajar", fontsize=11, penwidth=2];

    // ── Koneksi ──
    GURU -- Mengajar [label="1", fontsize=14, fontcolor=black];
    Mengajar -- MAPEL [label="N", fontsize=14, fontcolor=black];

    // ── Atribut GURU (ellipses, PK = tebal) ──
    NIP [shape=ellipse, label=<<U>NIP</U>>, fontsize=10, penwidth=2];
    Nama_Guru [shape=ellipse, label="Nama_Guru", fontsize=10];
    Spesialisasi [shape=ellipse, label="Spesialisasi", fontsize=10];
    No_Telepon_G [shape=ellipse, label="No_Telepon", fontsize=10];
    Alamat_G [shape=ellipse, label="Alamat", fontsize=10];
    Email [shape=ellipse, label="Email", fontsize=10];
    Pendidikan [shape=ellipse, label="Pendidikan_Terakhir", fontsize=10];

    GURU -- NIP;
    GURU -- Nama_Guru;
    GURU -- Spesialisasi;
    GURU -- No_Telepon_G;
    GURU -- Alamat_G;
    GURU -- Email;
    GURU -- Pendidikan;

    // ── Atribut MAPEL (ellipses, PK = tebal) ──
    Kode_Mapel [shape=ellipse, label=<<U>Kode_Mapel</U>>, fontsize=10, penwidth=2];
    Nama_Mapel [shape=ellipse, label="Nama_Mapel", fontsize=10];
    Tingkat_Kelas [shape=ellipse, label="Tingkat_Kelas", fontsize=10];
    KKM [shape=ellipse, label="KKM", fontsize=10];
    Semester [shape=ellipse, label="Semester", fontsize=10];
    Kurikulum [shape=ellipse, label="Kurikulum", fontsize=10];

    MAPEL -- Kode_Mapel;
    MAPEL -- Nama_Mapel;
    MAPEL -- Tingkat_Kelas;
    MAPEL -- KKM;
    MAPEL -- Semester;
    MAPEL -- Kurikulum;
}
