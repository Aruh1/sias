// Tabel Relasi - Sistem Informasi Akademik Sekolah (SIAS)
digraph Tabel_Relasi {
    graph [bgcolor=white, fontname="Arial", pad=0.5, nodesep=1.0, ranksep=1.5,
           label="Tabel Relasi - Sistem Informasi Akademik Sekolah (SIAS)",
           labelloc=t, fontsize=16, fontcolor=black];
    node [fontname="Courier", fontcolor=black, fontsize=10];
    edge [fontname="Arial", fontsize=9, color="#ea580c", penwidth=1.5];

    // ── Tabel ──
    tb_siswa [shape=record, style=filled, fillcolor="#f8fafc",
              label=<
                <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
                    <TR><TD BGCOLOR="#2563eb" COLSPAN="2"><FONT COLOR="white"><B>tb_siswa</B></FONT></TD></TR>
                    <TR><TD ALIGN="LEFT"><FONT COLOR="#dc2626"><B>[PK] NIS</B></FONT></TD></TR>
                    <TR><TD ALIGN="LEFT">Nama_Siswa</TD></TR>
                    <TR><TD ALIGN="LEFT">Tanggal_Lahir</TD></TR>
                    <TR><TD ALIGN="LEFT">Jenis_Kelamin</TD></TR>
                    <TR><TD ALIGN="LEFT">Alamat</TD></TR>
                    <TR><TD ALIGN="LEFT">No_Telepon</TD></TR>
                    <TR><TD ALIGN="LEFT">Agama</TD></TR>
                </TABLE>
              >];

    tb_guru [shape=record, style=filled, fillcolor="#f8fafc",
             label=<
                <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
                    <TR><TD BGCOLOR="#2563eb" COLSPAN="2"><FONT COLOR="white"><B>tb_guru</B></FONT></TD></TR>
                    <TR><TD ALIGN="LEFT"><FONT COLOR="#dc2626"><B>[PK] NIP</B></FONT></TD></TR>
                    <TR><TD ALIGN="LEFT">Nama_Guru</TD></TR>
                    <TR><TD ALIGN="LEFT">Spesialisasi</TD></TR>
                    <TR><TD ALIGN="LEFT">No_Telepon</TD></TR>
                    <TR><TD ALIGN="LEFT">Alamat</TD></TR>
                    <TR><TD ALIGN="LEFT">Email</TD></TR>
                    <TR><TD ALIGN="LEFT">Pendidikan_Terakhir</TD></TR>
                </TABLE>
             >];

    tb_mapel [shape=record, style=filled, fillcolor="#f8fafc",
              label=<
                <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
                    <TR><TD BGCOLOR="#2563eb" COLSPAN="2"><FONT COLOR="white"><B>tb_mapel</B></FONT></TD></TR>
                    <TR><TD ALIGN="LEFT"><FONT COLOR="#dc2626"><B>[PK] Kode_Mapel</B></FONT></TD></TR>
                    <TR><TD ALIGN="LEFT">Nama_Mapel</TD></TR>
                    <TR><TD ALIGN="LEFT">Tingkat_Kelas</TD></TR>
                    <TR><TD ALIGN="LEFT">KKM</TD></TR>
                    <TR><TD ALIGN="LEFT">Semester</TD></TR>
                    <TR><TD ALIGN="LEFT">Kurikulum</TD></TR>
                    <TR><TD ALIGN="LEFT"><FONT COLOR="#ea580c"><I>[FK] NIP</I></FONT></TD></TR>
                </TABLE>
              >];

    tb_nilai [shape=record, style=filled, fillcolor="#f8fafc",
              label=<
                <TABLE BORDER="0" CELLBORDER="1" CELLSPACING="0" CELLPADDING="6">
                    <TR><TD BGCOLOR="#2563eb" COLSPAN="2"><FONT COLOR="white"><B>tb_nilai</B></FONT></TD></TR>
                    <TR><TD ALIGN="LEFT"><FONT COLOR="#dc2626"><B>[PK] ID_Nilai</B></FONT></TD></TR>
                    <TR><TD ALIGN="LEFT"><FONT COLOR="#ea580c"><I>[FK] NIS</I></FONT></TD></TR>
                    <TR><TD ALIGN="LEFT"><FONT COLOR="#ea580c"><I>[FK] Kode_Mapel</I></FONT></TD></TR>
                    <TR><TD ALIGN="LEFT">Nilai_Tugas</TD></TR>
                    <TR><TD ALIGN="LEFT">Nilai_UTS</TD></TR>
                    <TR><TD ALIGN="LEFT">Nilai_UAS</TD></TR>
                </TABLE>
              >];

    // ── Foreign Key Relationships ──
    tb_mapel -> tb_guru [label="1 : N", dir=forward];
    tb_nilai -> tb_siswa [label="1 : N", dir=forward];
    tb_nilai -> tb_mapel [label="1 : N", dir=forward];
}
